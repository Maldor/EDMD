#!/bin/sh
# flatpak/edmd-launcher — wrapper script installed to /app/bin/edmd
# Runs EDMD inside the Flatpak sandbox.
# The git-based upgrade path (--upgrade) is not available in Flatpak;
# updates are delivered via "flatpak update com.drworman.EDMD".

export PYTHONPATH="/app/lib/python3/site-packages:${PYTHONPATH:-}"
export EDMD_SRC_DIR="/app/edmd"

exec python3 /app/edmd/edmd.py "$@"
